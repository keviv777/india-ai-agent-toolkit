            {
              "id": "b1",
              "name": "aiReply",
              "type": "string",
              "value": "={{ $json.response }}"
            },
            {
              "id": "b2",
              "name": "detectedStatus",
              "type": "string",
              "value": "={{ ($json.response.match(/\\[STATUS: (INTERESTED|NURTURING|NOT INTERESTED)\\]/) || ['','NURTURING'])[1] }}"
            },
            {
              "id": "b3",
              "name": "cleanReply",
              "type": "string",
              "value": "={{ $json.response.replace(/\\n?\\[STATUS:[A-Z ]+\\]/g, '').trim() }}"
            },
            {
              "id": "b4",
              "name": "phone",
              "type": "string",
              "value": "={{ $('Extract Phone and Message').item.json.phone }}"
            }
          ]
        },
        "options": {}
