              "name": "prompt",
              "value": "=Brand: {{ $('Lookup Lead in Google Sheets').item.json['Brand Name'] ?? 'Unknown' }}\nCustomer message: {{ $('Extract Phone and Message').item.json.incomingMessage }}"
            },
            {
              "name": "system",
              "value": "You are a friendly sales assistant for Mooshuree, a content creation agency that makes UGC videos and product reels for brands. Keep replies short, warm and professional (2-4 lines max for WhatsApp). End EVERY reply with exactly one of these tags on a new line:\n[STATUS: INTERESTED]\n[STATUS: NURTURING]\n[STATUS: NOT INTERESTED]"
            },
            {
              "name": "stream",
              "value": false
            }
          ]
        },
        "options": {}
